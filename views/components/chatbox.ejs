<div class="chat-widget" id="chatWidget">
    <button class="chat-bubble" id="chatTrigger">
        <i class="fas fa-comment-dots"></i>
        <div class="chat-badge" id="chatBadge" style="display: none;"></div>
    </button>

    <div class="chat-window" id="chatWindow">
        <div class="chat-header">
            <div class="chat-header-user">
                <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?q=80&w=100" alt="Bot">
                <div class="chat-header-info">
                    <h4>G-Bot Trợ lý 🌿</h4>
                    <p>Sẵn sàng hỗ trợ bạn</p>
                </div>
            </div>
            <button id="closeChat" style="background: none; border: none; color: white; cursor: pointer; font-size: 1.2rem;">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <div class="chat-body" id="chatBody">
            <!-- Messages will appear here -->
        </div>

        <div class="chat-footer">
            <input type="text" id="chatInput" placeholder="Nhập tin nhắn..." autocomplete="off">
            <button id="sendMsg">
                <i class="fas fa-paper-plane"></i>
            </button>
        </div>
    </div>
</div>

<script>
    const chatWidget = document.getElementById('chatWidget');
    const chatTrigger = document.getElementById('chatTrigger');
    const chatWindow = document.getElementById('chatWindow');
    const chatBody = document.getElementById('chatBody');
    const chatInput = document.getElementById('chatInput');
    const sendMsg = document.getElementById('sendMsg');
    const closeChat = document.getElementById('closeChat');
    const chatBadge = document.getElementById('chatBadge');

    let hasOpened = false;

    // Levenshtein / Fuzzy Match Logic
    const botAnswers = {
        "chào": "Chào bạn! Mình là G-Bot, trợ lý ảo của Green Library. Mình có thể giúp gì cho bạn?",
        "hi": "Chào bạn! Chúc bạn một ngày đọc sách thật hiệu quả.",
        "mượn sách": "Để mượn sách, bạn hãy chọn cuốn sách yêu thích, nhấn 'Mượn ngay' và chọn ngày trả nhé. Lưu ý bạn mượn tối đa 10 cuốn.",
        "trả sách": "Bạn vui lòng mang sách đến quầy thủ thư để trả. Chúng mình sẽ cập nhật trạng thái ngay sau đó.",
        "giờ làm việc": "Thư viện mở cửa từ 7:30 đến 21:00 các ngày trong tuần, và 8:00 đến 17:00 vào cuối tuần bạn nhé.",
        "thời gian": "Thư viện mở cửa từ 7:30 đến 21:00 các ngày trong tuần, và 8:00 đến 17:00 vào cuối tuần bạn nhé.",
        "gia hạn": "Bạn có thể vào mục 'Tủ sách của tôi', chọn cuốn sách muốn gia hạn và nhấn 'Gia hạn' (tổng cộng tối đa 30 ngày).",
        "địa chỉ": "Thư viện nằm tại tầng 2, tòa nhà Trung tâm Tri thức đấy!",
        "cảm ơn": "Rất vui được hỗ trợ bạn! Hẹn gặp lại nhé. 🌿"
    };

    // Calculate similarity between two strings
    function similarity(s1, s2) {
        let longer = s1.length > s2.length ? s1 : s2;
        let shorter = s1.length > s2.length ? s2 : s1;
        if (longer.length == 0) return 1.0;
        let costs = new Array();
        for (let i = 0; i <= longer.length; i++) {
            let lastValue = i;
            for (let j = 0; j <= shorter.length; j++) {
                if (i == 0) costs[j] = j;
                else {
                    if (j > 0) {
                        let newValue = costs[j - 1];
                        if (longer.charAt(i - 1) != shorter.charAt(j - 1))
                            newValue = Math.min(Math.min(newValue, lastValue), costs[j]) + 1;
                        costs[j - 1] = lastValue;
                        lastValue = newValue;
                    }
                }
            }
            if (i > 0) costs[shorter.length] = lastValue;
        }
        return (longer.length - costs[shorter.length]) / parseFloat(longer.length);
    }

    function addMessage(text, sender = 'bot', isHtml = false) {
        const div = document.createElement('div');
        div.className = `msg msg-${sender}`;
        if (isHtml) {
            div.innerHTML = text;
        } else {
            div.innerText = text;
        }
        chatBody.appendChild(div);
        chatBody.scrollTop = chatBody.scrollHeight;
    }

    function showTyping() {
        const typing = document.createElement('div');
        typing.className = 'typing-container';
        typing.id = 'typingIndicator';
        typing.innerHTML = `
            <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?q=80&w=100">
            <div class="typing">
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
            </div>
        `;
        chatBody.appendChild(typing);
        chatBody.scrollTop = chatBody.scrollHeight;
        return typing;
    }

    async function searchBooks(query) {
        try {
            const res = await fetch('/api/search?q=' + encodeURIComponent(query));
            const data = await res.json();
            return data.books || [];
        } catch (e) {
            return [];
        }
    }

    async function botRespond(userText) {
        const indicator = showTyping();
        
        // Wait realistic typing time
        await new Promise(r => setTimeout(r, 1000));
        
        const lowerText = userText.toLowerCase().trim();
        
        // 1. Check for Book Search intent
        if (lowerText.startsWith("tìm") || lowerText.includes("có sách") || lowerText.includes("cho hỏi sách")) {
            // Extract keyword
            let keyword = lowerText.replace(/tìm sách|tìm kiếm|tìm|có sách|cho hỏi sách|không|nhé/g, "").trim();
            if (keyword.length > 1) {
                const books = await searchBooks(keyword);
                indicator.remove();
                if (books.length > 0) {
                    let html = `<p>Mình tìm thấy ${books.length} kết quả cho "<b>${keyword}</b>":</p>`;
                    html += `<div style="display:flex; flex-direction:column; gap:10px; margin-top:10px;">`;
                    books.slice(0, 3).forEach(b => {
                        html += `
                        <a href="/book/${b.id}" style="display:flex; gap:10px; text-decoration:none; color:inherit; background:#F9F9F9; padding:8px; border-radius:8px;">
                            <img src="${b.cover}" style="width:40px; height:60px; object-fit:cover; border-radius:4px;">
                            <div style="font-size:0.85rem;">
                                <strong style="display:block; color:var(--primary); line-height:1.2; margin-bottom:3px">${b.title}</strong>
                                <span style="color:#666;">Kho: ${b.quantity > 0 ? b.quantity + ' cuốn' : '<span style="color:red">Hết sách</span>'}</span>
                            </div>
                        </a>`;
                    });
                    if (books.length > 3) html += `<a href="/?q=${keyword}" style="font-size:0.85rem; text-align:center; display:block; color:var(--primary);">Xem tất cả kết quả...</a>`;
                    html += `</div>`;
                    addMessage(html, 'bot', true);
                    return;
                } else {
                    addMessage(`Tiếc quá, hiện tại thư viện chưa có cuốn sách nào liên quan đến "${keyword}" rùi.`, 'bot');
                    return;
                }
            }
        }

        // 2. Fuzzy QA Match
        indicator.remove();
        let bestMatch = null;
        let highestScore = 0;
        
        // Trích xuất các từ khóa dài từ câu người dùng để so khớp tốt hơn
        const words = lowerText.split(' ').filter(w => w.length >= 3);
        
        for (const key in botAnswers) {
            // If exact match substring
            if (lowerText.includes(key)) {
                bestMatch = key;
                highestScore = 1;
                break;
            }
            // Or fuzzy match words
            for (const word of words) {
                const score = similarity(word, key);
                if (score > highestScore && score >= 0.6) { // 60% similarity threshold
                    bestMatch = key;
                    highestScore = score;
                }
            }
        }

        if (bestMatch && highestScore >= 0.6) {
            addMessage(botAnswers[bestMatch], 'bot');
        } else {
            addMessage("Câu này hơi khó với mình rùi. Bạn có thể hỏi về các chủ đề như: 'mượn sách', 'gia hạn', 'thời gian', 'địa chỉ', hoặc thử nhắn 'Tìm sách [tên sách]' để mình tra cứu giúp nha!", 'bot');
        }
    }

    function toggleChat() {
        chatWindow.classList.toggle('open');
        chatBadge.style.display = 'none';
        if (chatWindow.classList.contains('open')) {
            chatInput.focus();
            hasOpened = true;
        }
    }

    chatTrigger.addEventListener('click', toggleChat);
    closeChat.addEventListener('click', toggleChat);

    function handleSend() {
        const text = chatInput.value.trim();
        if (!text) return;

        addMessage(text, 'user');
        chatInput.value = '';
        botRespond(text);
    }

    sendMsg.addEventListener('click', handleSend);
    chatInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') handleSend();
    });

    // Auto-open logic after 5 seconds
    window.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => {
            if (!hasOpened) {
                chatWindow.classList.add('open');
                chatBadge.style.display = 'block';
                addMessage("Chào mừng bạn trở lại với Green Library! Mình là G-Bot, mình có thể giúp bạn tìm sách hoặc hướng dẫn mượn trả đấy. 🌿", 'bot');
            }
        }, 5000);
    });
</script>
