<%- include('./layout/header') %>

<section class="admin-stats">
    <div class="stat-tile featured">
        <p>Tổng sách trong kho</p>
        <h2><%= stats.totalBooks.toLocaleString() %></h2>
        <p style="font-size: 0.65rem; opacity: 0.7;">Dữ liệu từ Firestore</p>
    </div>
    <div class="stat-tile">
        <p style="color: #999;">Thành viên hệ thống</p>
        <h2 style="color: var(--text-dark);"><%= stats.totalUsers.toLocaleString() %></h2>
    </div>
    <div class="stat-tile">
        <p style="color: #999;">Sách đang mượn</p>
        <h2 style="color: var(--text-dark);"><%= stats.borrowingCount.toLocaleString() %></h2>
    </div>
    <div class="stat-tile">
        <p style="color: #999;">Dung lượng kho</p>
        <h2 style="color: var(--text-dark);"><%= stats.storageUsed %>%</h2>
    </div>
</section>

<div class="admin-inventory-wrapper">
    <% Object.keys(groupedBooks).forEach(category => { %>
        <div class="category-section">
            <h3 class="category-header"><i class="fas fa-folder"></i> <%= category %></h3>
            <div class="admin-table-container">
                <table>
                    <thead>
                        <tr>
                            <th style="width: 80px;">Bìa</th>
                            <th>Tên sách & Tác giả</th>
                            <th>Số lượng</th>
                            <th>Nổi bật</th>
                            <th style="text-align: right;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% groupedBooks[category].forEach(book => { %>
                            <tr>
                                <td>
                                    <img src="<%= book.cover %>" style="width: 50px; height: 70px; object-fit: cover; border-radius: 6px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
                                </td>
                                <td>
                                    <div style="font-weight: 700; color: var(--text-dark);"><%= book.title %></div>
                                    <div style="font-size: 0.8rem; color: #999; margin-top: 4px;"><%= book.author %></div>
                                </td>
                                <td>
                                    <span class="quantity-badge <%= (book.quantity || 0) > 0 ? 'in-stock' : 'out-of-stock' %>">
                                        <%= book.quantity || 0 %> / <%= book.totalQuantity || book.quantity || 1 %>
                                    </span>
                                </td>
                                <td>
                                    <% if (book.isFeatured) { %>
                                        <span style="color: #FFD700;"><i class="fas fa-star"></i></span>
                                    <% } else { %>
                                        <span style="color: #EEE;"><i class="far fa-star"></i></span>
                                    <% } %>
                                </td>
                                <td style="text-align: right;">
                                    <div class="action-buttons">
                                        <a href="/admin/edit-book/<%= book.id %>" class="btn-edit" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i> Sửa
                                        </a>
                                        <a href="/admin/delete-book/<%= book.id %>" class="btn-delete" title="Xóa" onclick="return confirm('Bạn có chắc muốn xóa cuốn sách này không?')">
                                            <i class="fas fa-trash-alt"></i> Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    <% }) %>
</div>

<style>
.admin-inventory-wrapper {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
}

.category-header {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    color: var(--primary);
    display: flex;
    align-items: center;
    gap: 12px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--bg-soft);
}

.quantity-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
}

.quantity-badge.in-stock {
    background: #E8F5E9;
    color: #2E7D32;
}

.quantity-badge.out-of-stock {
    background: #FFEBEE;
    color: #C62828;
}

.action-buttons {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
}

.btn-edit, .btn-delete {
    padding: 8px 16px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    transition: 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
}

.btn-edit {
    background: #F0F7FF;
    color: #0061D5;
}

.btn-edit:hover {
    background: #0061D5;
    color: white;
}

.btn-delete {
    background: #FFF5F5;
    color: #E53935;
}

.btn-delete:hover {
    background: #E53935;
    color: white;
}

.admin-table-container {
    background: white;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
}

table {
    width: 100%;
    border-collapse: collapse;
}

th, td {
    padding: 1.25rem 1.5rem;
    text-align: left;
    border-bottom: 1px solid #F5F5F5;
}

th {
    background: #FAFAFA;
    font-size: 0.8rem;
    text-transform: uppercase;
    color: #999;
}
</style>

<%- include('./layout/footer') %>
