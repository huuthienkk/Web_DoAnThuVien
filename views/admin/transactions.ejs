<%- include('./layout/header') %>

<section class="admin-stats" style="margin-bottom: 2rem;">
    <div class="stat-tile featured">
        <p>Tổng phiếu mượn</p>
        <h2><%= transactions.length %></h2>
    </div>
    <div class="stat-tile">
        <p style="color: #999;">Đang hoạt động</p>
        <h2 style="color: var(--text-dark);"><%= stats.borrowingCount %></h2>
    </div>
    <div class="stat-tile">
        <p style="color: #999;">Quá hạn</p>
        <h2 style="color: #E74C3C;"><%= stats.overdueCount %></h2>
    </div>
</section>

<div class="admin-table-container">
    <div style="padding: 1.5rem; border-bottom: 1px solid #EEE; display: flex; justify-content: space-between; align-items: center; background: #FAFAFA;">
        <h3 style="font-size: 1.1rem; color: var(--text-dark);">Danh sách phiếu mượn</h3>
        
        <form action="/admin/transactions" method="GET" style="display: flex; gap: 10px; flex: 1; max-width: 400px; margin-left: 2rem;">
            <div style="position: relative; flex: 1;">
                <input type="text" name="search" placeholder="Tìm theo mã phiếu hoặc MSSV..." value="<%= locals.search || '' %>" style="width: 100%; padding: 10px 15px 10px 35px; border-radius: 8px; border: 1px solid #DDD; outline: none; font-size: 0.85rem;">
                <i class="fas fa-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #999; font-size: 0.8rem;"></i>
            </div>
            <button type="submit" style="background: var(--primary); color: white; border: none; padding: 0 20px; border-radius: 8px; font-weight: 600; cursor: pointer;">Tìm</button>
        </form>
    </div>

    <table>
        <thead>
            <tr>
                <th>Mã phiếu</th>
                <th>Sách / Tài liệu</th>
                <th>Người mượn (MSSV)</th>
                <th>Ngày mượn</th>
                <th>Hạn trả</th>
                <th>Trạng thái</th>
                <th style="text-align: right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <% transactions.forEach(tx => { %>
                <tr>
                    <td>
                        <span style="font-family: monospace; font-weight: 800; color: var(--primary); background: #E8F5E9; padding: 4px 8px; border-radius: 4px; border: 1px dashed var(--primary);">
                            <%= tx.slipCode || 'N/A' %>
                        </span>
                    </td>
                    <td>
                        <div style="font-weight: 600;"><%= tx.bookTitle %></div>
                        <div style="font-size: 0.7rem; color: #999;">ID: <%= (tx.bookId || '').substring(0, 8).toUpperCase() %></div>
                    </td>
                    <td>
                        <div style="font-weight: 600;"><%= locals.user && user.id === tx.userId ? user.name : 'Sinh viên' %></div>
                        <div style="font-size: 0.75rem; color: #999;"><%= tx.userId || 'N/A' %></div>
                    </td>
                    <td><%= tx.date %></td>
                    <td class="<%= tx.status === 'Overdue' ? 'text-overdue' : '' %>">
                        <%= tx.dueDate %>
                    </td>
                    <td>
                        <% if (tx.status === 'Active') { %>
                            <span class="status-tag tag-active">Chờ sinh viên nhận</span>
                        <% } else if (tx.status === 'Borrowed') { %>
                            <span class="status-tag tag-borrowed">Sinh viên đã mượn</span>
                        <% } else if (tx.status === 'Returned') { %>
                            <span class="status-tag tag-returned">Sinh viên đã trả</span>
                        <% } else { %>
                            <span class="status-tag tag-<%= (tx.status || '').toLowerCase() %>"><%= tx.status %></span>
                        <% } %>
                    </td>
                    <td style="text-align: right;">
                        <div style="display: flex; gap: 5px; justify-content: flex-end;">
                            <button onclick="updateStatus('<%= tx.id %>', 'Borrowed')" class="btn-sm btn-borrow" <%= tx.status === 'Borrowed' || tx.status === 'Returned' || tx.status === 'Cancelled' ? 'disabled' : '' %> title="Xác nhận mượn">
                                Đã mượn
                            </button>
                            <button onclick="updateStatus('<%= tx.id %>', 'Returned')" class="btn-sm btn-return" <%= tx.status === 'Returned' || tx.status === 'Active' || tx.status === 'Cancelled' ? 'disabled' : '' %> title="Xác nhận trả">
                                Đã trả
                            </button>
                            <button onclick="updateStatus('<%= tx.id %>', 'Cancelled')" class="btn-sm" style="background: #EEE; color: #666;" <%= tx.status === 'Returned' || tx.status === 'Cancelled' ? 'disabled' : '' %> title="Hủy phiếu">
                                Hủy
                            </button>
                        </div>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<script>
async function updateStatus(id, status) {
    if (!confirm(`Bạn muốn cập nhật trạng thái này sang "${status}"?`)) return;
    
    try {
        const response = await fetch('/admin/update-transaction-status', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify({ id, status })
        });
        const result = await response.json();
        if (result.success) {
            location.reload(); // Still reloading for simplicity to update stats/tags, but now via AJAX
        } else {
            alert('Lỗi: ' + result.message);
        }
    } catch (e) {
        console.error(e);
        alert('Lỗi hệ thống');
    }
}
</script>

<style>
.status-tag {
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
}
.tag-active, .tag-borrowed { background: #E8F5E9; color: #2E7D32; }
.tag-overdue { background: #FDEDEC; color: #E74C3C; }
.tag-returned { background: #F4F7F4; color: #999; }
.text-overdue { color: #E74C3C; font-weight: 700; }
.btn-sm { padding: 4px 10px; border-radius: 6px; font-size: 0.7rem; font-weight: 700; border: none; cursor: pointer; transition: 0.2s; white-space: nowrap; }
.btn-sm:disabled { opacity: 0.3; cursor: not-allowed; }
.btn-borrow { background: var(--primary); color: white; }
.btn-return { background: var(--secondary); color: white; }
</style>

</body>
</html>
