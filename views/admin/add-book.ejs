<%- include('./layout/header') %>

<div class="admin-form-container">
    <div class="form-header">
        <a href="/admin/dashboard" class="back-link"><i class="fas fa-arrow-left"></i> Quay lại</a>
        <h2>Thêm tài liệu mới vào thư viện</h2>
        <p>Hệ thống sẽ tự động cập nhật vào danh mục Khám phá sau khi lưu.</p>
    </div>

    <form action="/admin/add-book" method="POST" class="admin-form">
        <div class="form-grid">
            <!-- Thông tin cơ bản -->
            <div class="form-group">
                <label for="title">Tiêu đề sách *</label>
                <input type="text" id="title" name="title" placeholder="Nhập tên sách..." required>
            </div>

            <div class="form-group">
                <label for="author">Tác giả *</label>
                <input type="text" id="author" name="author" placeholder="Tên tác giả..." required>
            </div>

            <div class="form-group">
                <label for="category">Thể loại *</label>
                <select id="category" name="category" required>
                    <option value="">-- Chọn thể loại --</option>
                    <option value="Kiến trúc">Kiến trúc</option>
                    <option value="Kỹ thuật">Kỹ thuật</option>
                    <option value="Kinh tế">Kinh tế</option>
                    <option value="Tâm lý">Tâm lý</option>
                    <option value="Lịch sử">Lịch sử</option>
                    <option value="Nghệ thuật">Nghệ thuật</option>
                </select>
            </div>

            <div class="form-group">
                <label for="status">Trạng thái ban đầu</label>
                <select id="status" name="status">
                    <option value="Available">Sẵn sàng (Available)</option>
                    <option value="Maintenance">Bảo trì (Maintenance)</option>
                </select>
            </div>

            <div class="form-group">
                <label for="quantity">Số lượng nhập kho *</label>
                <input type="number" id="quantity" name="quantity" min="1" value="1" required>
            </div>

            <!-- Hình ảnh & Nổi bật -->
            <div class="form-group full-width">
                <label for="cover">Link ảnh bìa (URL)</label>
                <input type="url" id="cover" name="cover" placeholder="https://example.com/image.jpg">
                <small>Nếu trống, hệ thống sẽ sử dụng ảnh mặc định.</small>
            </div>

            <div class="form-group checkbox-group">
                <input type="checkbox" id="isFeatured" name="isFeatured">
                <label for="isFeatured">Đánh dấu là sách nổi bật (Hiển thị trang chủ)</label>
            </div>
        </div>

        <div class="form-actions">
            <button type="reset" class="btn-secondary-outline">Hủy bỏ</button>
            <button type="submit" class="btn-primary-solid">Lưu tài liệu</button>
        </div>
    </form>
</div>

<style>
.admin-form-container {
    max-width: 900px;
    margin: 2rem auto;
    background: white;
    padding: 2.5rem;
    border-radius: 20px;
    box-shadow: var(--shadow);
}

.form-header {
    margin-bottom: 2.5rem;
}

.back-link {
    color: var(--primary);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 700;
    display: inline-block;
    margin-bottom: 1rem;
}

.admin-form h2 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
}

.form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
}

.full-width {
    grid-column: span 2;
}

.form-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: #444;
}

.form-group input, 
.form-group select {
    width: 100%;
    padding: 12px 16px;
    border-radius: 10px;
    border: 1px solid #EEE;
    outline: none;
    font-family: inherit;
    background: #F9F9F9;
    transition: 0.3s;
}

.form-group input:focus {
    border-color: var(--primary);
    background: white;
}

.checkbox-group {
    display: flex;
    align-items: center;
    gap: 10px;
    grid-column: span 2;
    padding: 1rem;
    background: var(--bg-soft);
    border-radius: 12px;
}

.checkbox-group input {
    width: 18px;
    height: 18px;
}

.form-actions {
    margin-top: 3rem;
    display: flex;
    justify-content: flex-end;
    gap: 1.5rem;
}

.btn-secondary-outline {
    padding: 12px 30px;
    border: 1px solid #DDD;
    background: transparent;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
}

.btn-primary-solid {
    padding: 12px 40px;
    background: var(--primary);
    color: white;
    border: none;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
}
</style>

<%- include('./layout/footer') %>
