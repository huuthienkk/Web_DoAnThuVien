<%- include('./layout/header') %>

<section class="admin-stats" style="margin-bottom: 2rem;">
    <div class="stat-tile">
        <p style="color: #999;">Tổng thành viên</p>
        <h2 style="color: var(--primary);"><%= stats.totalUsers %></h2>
    </div>
    <div class="stat-tile">
        <p style="color: #999;">Đang hoạt động</p>
        <h2 style="color: var(--secondary);"><%= stats.totalUsers %></h2>
    </div>
    <div class="stat-tile">
        <p style="color: #999;">Đang bị khóa</p>
        <h2 style="color: #E74C3C;">0</h2>
    </div>
</section>

<div class="admin-table-container">
    <div style="padding: 1rem 1.5rem; border-bottom: 1px solid #EEE; display: flex; justify-content: space-between; align-items: center;">
        <h3>Danh bạ thành viên</h3>
        <a href="/admin/add-book" style="background: var(--primary); color: white; border: none; padding: 10px 20px; border-radius: 8px; font-size: 0.85rem; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 1.2rem; line-height: 1;">+</span> Thêm tài liệu mới
        </a>
    </div>
    <table>
        <thead>
            <tr>
                <th>Mã SV / ID</th>
                <th>Thành viên</th>
                <th>Lớp / Bộ phận</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(user => { %>
                <tr>
                    <td style="font-family: monospace; font-weight: 500; color: #999;"><%= user.id %></td>
                    <td>
                        <div class="user-cell">
                            <img src="<%= user.avatar %>" alt="<%= user.name %>">
                            <div>
                                <div style="font-weight: 600;"><%= user.name %></div>
                                <div style="font-size: 0.7rem; color: #999;"><%= user.email %></div>
                            </div>
                        </div>
                    </td>
                    <td><%= user.dept %></td>
                    <td>
                        <span class="status-tag tag-<%= user.status.toLowerCase() %>"><%= user.status === 'Active' ? 'Hoạt động' : 'Đã khóa' %></span>
                    </td>
                    <td>
                        <div style="display: flex; gap: 10px;">
                            <button style="background: none; border: none; cursor: pointer; color: #999;">
                                <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            </button>
                            <button style="background: none; border: none; cursor: pointer; color: #999;">
                                <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                            </button>
                        </div>
                    </td>
                </tr>
            <%  }) %>
        </tbody>
    </table>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; margin-top: 2rem;">
    <div style="background: linear-gradient(135deg, var(--primary), var(--primary-light)); padding: 2.5rem; border-radius: 20px; color: white;">
        <p style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; opacity: 0.8;">Tính năng mới</p>
        <h2 style="font-size: 2.4rem; margin: 1rem 0;">Gia hạn thành viên tự động qua Email.</h2>
        <p style="opacity: 0.9; line-height: 1.6; max-width: 450px; margin-bottom: 2rem;">Tiết kiệm thời gian quản lý bằng cách thiết lập quy trình tự động nhắc nhở và gia hạn cho sinh viên năm cuối.</p>
        <button style="background: white; color: var(--primary); border: none; padding: 12px 30px; border-radius: 25px; font-weight: 700; cursor: pointer;">Khám phá ngay</button>
    </div>
    <div style="background: #F0F4F0; padding: 2.5rem; border-radius: 20px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
        <div style="width: 50px; height: 50px; background: white; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; box-shadow: var(--shadow);">
            <svg style="width: 24px; height: 24px; color: var(--primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        </div>
        <h3 style="margin-bottom: 0.5rem;">Bảo mật dữ liệu</h3>
        <p style="font-size: 0.85rem; color: #666; line-height: 1.6; margin-bottom: 1.5rem;">Tất cả dữ liệu thành viên được mã hóa theo tiêu chuẩn an toàn thông tin quốc gia.</p>
        <a href="#" style="color: var(--primary); font-weight: 700; text-decoration: none; font-size: 0.85rem;">Xem báo cáo an ninh →</a>
    </div>
</div>

</body>
</html>
