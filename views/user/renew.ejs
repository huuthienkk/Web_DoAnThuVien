<%- include('../components/header') %>

<div class="auth-card" style="max-width: 600px; margin: 2rem auto;">
    <div class="auth-header">
        <h2 style="color: var(--primary); font-size: 1.8rem; margin-bottom: 0.5rem;">Gia hạn mượn sách</h2>
        <p style="color: #666; font-size: 0.9rem;">Bạn đang gia hạn cho cuốn sách: <strong><%= transaction.bookTitle %></strong></p>
    </div>

    <div class="borrow-info-box" style="background: #F9F9F9; padding: 1.5rem; border-radius: 12px; margin: 1.5rem 0; border: 1px dashed #DDD;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
            <span style="color: #888;">Mã phiếu mượn:</span>
            <span style="font-weight: 700; color: #333;"><%= transaction.slipCode %></span>
        </div>
        <div style="display: flex; justify-content: space-between;">
            <span style="color: #888;">Hạn trả hiện tại:</span>
            <span style="font-weight: 700; color: #E74C3C;"><%= currentDueDate %></span>
        </div>
    </div>

    <form action="/renew/<%= transaction.id %>" method="POST" class="auth-form">
        <div class="form-group">
            <label for="newDueDate">Chọn ngày trả mới khách hàng mong muốn</label>
            <input type="date" id="newDueDate" name="newDueDate" required 
                   style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #DDD; font-family: inherit;">
            <p style="font-size: 0.75rem; color: #999; margin-top: 8px;">
                * Lưu ý: Ngày trả mới không được vượt quá 30 ngày kể từ hôm nay.
            </p>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 2rem;">
            <a href="/borrowing" class="btn-text" style="text-align: center; border: 1px solid #DDD; border-radius: 8px; padding: 12px;">Hủy bỏ</a>
            <button type="submit" class="auth-btn" style="margin-top: 0;">Xác nhận gia hạn</button>
        </div>
    </form>
</div>

<script>
    // Set minimum date to today + 1 day
    const today = new Date();
    today.setDate(today.getDate() + 1);
    const minDate = today.toISOString().split('T')[0];
    
    // Set maximum date to today + 31 days
    const maxDateObj = new Date();
    maxDateObj.setDate(maxDateObj.getDate() + 30);
    const maxDate = maxDateObj.toISOString().split('T')[0];

    const dateInput = document.getElementById('newDueDate');
    dateInput.setAttribute('min', minDate);
    dateInput.setAttribute('max', maxDate);
    dateInput.value = minDate; // Default to tomorrow
</script>

<%- include('../components/footer') %>
