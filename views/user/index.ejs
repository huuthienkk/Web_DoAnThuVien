<%- include('../components/header') %>

<section>
    <h2>Chào buổi sáng, <%= (user.name && user.name.includes('Quản trị viên')) ? 'Thủ thư' : (user.name || 'bạn').split(' ').pop() %>.</h2>
    <p style="color: #666; margin-bottom: 2rem;">Hôm nay bạn muốn khám phá điều gì? Hệ thống thư viện có hơn 5,000 đầu sách mới được cập nhật trong tuần này.</p>
</section>

<% if (locals.searchQuery) { %>
    <section>
        <div class="section-title">
            <h3>Kết quả tìm kiếm: "<%= searchQuery %>"</h3>
            <p style="font-size: 0.9rem; color: #666;"><%= featuredBooks.length %> kết quả phù hợp</p>
        </div>
        
        <% if (featuredBooks.length > 0) { %>
            <div class="book-grid">
                <% featuredBooks.forEach(book => { %>
                    <div class="book-card" onclick="window.location.href='/book/<%= book.id %>'">
                        <div class="book-cover-wrapper">
                            <img src="<%= book.cover %>" class="book-cover" alt="<%= book.title %>">
                            <span class="badge badge-available">Sẵn có</span>
                        </div>
                        <div class="book-info">
                            <h4><%= book.title %></h4>
                            <p class="author"><%= book.author %></p>
                            <span class="category-tag" style="font-size: 0.7rem; background: #f0f4f8; padding: 2px 6px; border-radius: 4px;"><%= book.category %></span>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div style="text-align: center; padding: 3rem; background: #f9f9f9; border-radius: 12px; border: 2px dashed #eee;">
                <p style="font-size: 1.2rem; color: #999;">Rất tiếc, không tìm thấy tài liệu nào khớp với từ khóa của bạn.</p>
                <a href="/" style="display: inline-block; margin-top: 1rem; color: var(--primary); font-weight: 600;">Xem tất cả sách</a>
            </div>
        <% } %>
    </section>
<% } else { %>
    <section>
        <div class="section-title">
            <h3>Sách mới nhất</h3>
        </div>
        <div class="book-grid">
            <% featuredBooks.forEach(book => { %>
                <div class="book-card" onclick="window.location.href='/book/<%= book.id %>'">
                    <div class="book-cover-wrapper">
                        <img src="<%= book.cover %>" class="book-cover" alt="<%= book.title %>">
                        <span class="badge badge-available">Mới</span>
                    </div>
                    <div class="book-info">
                        <h4><%= book.title %></h4>
                        <p class="author"><%= book.author %></p>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>

    <% Object.keys(groupedBooks).forEach(category => { %>
        <section style="margin-top: 3rem;">
            <div class="section-title">
                <h3>Thể loại: <%= category %></h3>
                <a href="/?q=<%= encodeURIComponent(category) %>" class="view-all">Xem tất cả (<%= groupedBooks[category].length %>) →</a>
            </div>
            <div class="book-grid">
                <% groupedBooks[category].slice(0, 4).forEach(book => { %>
                    <div class="book-card" onclick="window.location.href='/book/<%= book.id %>'">
                        <div class="book-cover-wrapper">
                            <img src="<%= book.cover %>" class="book-cover" alt="<%= book.title %>">
                        </div>
                        <div class="book-info">
                            <h4><%= book.title %></h4>
                            <p class="author"><%= book.author %></p>
                        </div>
                    </div>
                <% }) %>
            </div>
        </section>
    <% }) %>
<% } %>

<section class="borrowing-list">
    <div class="section-title" style="margin-top: 0;">
        <h3>🌿 Sách đang mượn</h3>
    </div>
    
    <% borrowingBooks.forEach(book => { %>
        <div class="borrowing-item <%= book.status === 'Overdue' ? 'overdue' : '' %>" data-id="<%= book.transId %>">
            <div class="item-left">
                <img src="<%= book.cover %>" class="item-thumb" alt="<%= book.title %>">
                <div class="item-details">
                    <h4><%= book.title %></h4>
                    <p>Mã sách: <%= book.id_code %></p>
                    <p style="margin-top: 5px;">
                        <strong><%= book.borrowDate %></strong> <span style="margin: 0 5px; opacity: 0.3;">→</span> <strong><%= book.dueDate %></strong>
                    </p>
                </div>
            </div>
            
            <div class="item-meta">
                <div class="meta-box">
                    <span>Trạng thái</span>
                    <% if (book.status === 'Overdue') { %>
                        <div class="status-label status-overdue">Quá hạn <%= book.daysOverdue %> ngày</div>
                    <% } else { %>
                        <div class="status-label status-days">Còn <%= book.daysLeft %> ngày</div>
                    <% } %>
                </div>
            </div>
            
            <button class="btn-action">
                <%= book.status === 'Overdue' ? 'Liên hệ thư viện' : 'Gia hạn' %>
            </button>
        </div>
    <% }) %>
</section>

<script>
    document.querySelectorAll('.btn-action').forEach(button => {
        button.addEventListener('click', async (e) => {
            const item = e.target.closest('.borrowing-item');
            if (!item) return;
            
            // Logic for Renew if the text is "Gia hạn"
            if (e.target.innerText.trim() === 'Gia hạn') {
                const transId = item.getAttribute('data-id'); 
                try {
                    const res = await fetch(`/renew/${transId}`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        alert(data.message || 'Gia hạn thành công!');
                        location.reload();
                    } else {
                        alert('Lỗi: ' + (data.message || 'Không thể gia hạn'));
                    }
                } catch (err) {
                    console.error(err);
                    alert('Lỗi hệ thống khi gia hạn');
                }
            }
        });
    });
</script>

<%- include('../components/footer') %>
