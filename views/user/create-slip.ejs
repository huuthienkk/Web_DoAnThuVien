<%- include('../components/header') %>

<div class="create-slip-wrapper">
    <div class="breadcrumb">
        <a href="/">Khám phá</a> <i class="fas fa-chevron-right"></i> <a href="/book/<%= book.id %>">Chi tiết sách</a> <i class="fas fa-chevron-right"></i> <span>Tạo phiếu mượn</span>
    </div>

    <div class="slip-container">
        <!-- Left: Visual -->
        <div class="slip-visual">
            <img src="<%= book.cover %>" alt="<%= book.title %>" class="slip-book-cover">
        </div>

        <!-- Right: Slip Form -->
        <div class="slip-card">
            <div class="slip-header">
                <h2>Phiếu mượn tài liệu</h2>
                <p class="slip-note">Vui lòng kiểm tra thông tin và chọn ngày trả trước khi xác nhận.</p>
            </div>

            <div class="slip-body">
                <div class="book-title-large"><%= book.title %></div>
                
                <div class="slip-info-grid">
                    <div class="info-item">
                        <label>Mã sách</label>
                        <p><%= book.id_code || 'LIB-' + book.id.substring(0,6).toUpperCase() %></p>
                    </div>
                    <div class="info-item">
                        <label>Mã sinh viên</label>
                        <p><%= user.id %></p>
                    </div>
                </div>

                <div class="slip-code-box">
                    <label>Mã phiếu mượn (Dự kiến)</label>
                    <div class="code-value"><%= slipCode %></div>
                </div>

                <form action="/borrow/confirm/<%= book.id %>" method="POST" class="slip-form">
                    <div class="form-group">
                        <label for="returnDate">Ngày dự kiến trả *</label>
                        <input type="date" id="returnDate" name="returnDate" required 
                               min="<%= new Date().toISOString().split('T')[0] %>"
                               max="<%= new Date(Date.now() + 14 * 24 * 60 * 60 * 1000).toISOString().split('T')[0] %>">
                        <small class="limit-note"><i class="fas fa-clock"></i> Thời gian mượn tối đa là 14 ngày.</small>
                    </div>

                    <div class="note-box">
                        <i class="fas fa-info-circle"></i>
                        <p>Sinh viên vui lòng ghi nhớ mã phiếu mượn này để cung cấp cho thủ thư khi lên thư viện nhận sách trực tiếp. Lưu ý: <strong>Thời gian mượn sách tối đa là 14 ngày</strong> tính từ ngày nhận sách.</p>
                    </div>

                    <button type="submit" class="btn-confirm-slip">
                        <i class="fas fa-check-circle"></i> Xác nhận mượn sách
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
.create-slip-wrapper {
    padding: 2rem 0;
    max-width: 1000px;
    margin: 0 auto;
}

.breadcrumb {
    margin-bottom: 2rem;
    font-size: 0.9rem;
    color: #999;
    display: flex;
    align-items: center;
    gap: 10px;
}

.breadcrumb a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
}

.slip-container {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 3rem;
    align-items: start;
}

.slip-book-cover {
    width: 100%;
    border-radius: 20px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    aspect-ratio: 2/3;
    object-fit: cover;
}

.slip-card {
    background: white;
    border-radius: 25px;
    padding: 2.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border: 1px solid #F0F0F0;
}

.slip-header h2 {
    font-size: 1.8rem;
    color: var(--text-dark);
    margin-bottom: 0.5rem;
}

.slip-note {
    color: #999;
    font-size: 0.9rem;
}

.slip-body {
    margin-top: 2rem;
}

.book-title-large {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: 2rem;
    line-height: 1.3;
}

.slip-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.info-item label {
    display: block;
    font-size: 0.75rem;
    color: #999;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 5px;
}

.info-item p {
    font-size: 1.1rem;
    font-weight: 700;
    color: #444;
}

.slip-code-box {
    background: #F8F9F8;
    padding: 1.5rem;
    border-radius: 15px;
    border: 1px dashed var(--primary);
    margin-bottom: 2.5rem;
}

.slip-code-box label {
    display: block;
    font-size: 0.8rem;
    color: var(--primary);
    font-weight: 700;
    margin-bottom: 8px;
}

.code-value {
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.8rem;
    font-weight: 900;
    letter-spacing: 2px;
    color: var(--text-dark);
}

.form-group label {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 10px;
}

.form-group input {
    width: 100%;
    padding: 12px 16px;
    border-radius: 12px;
    border: 1px solid #DDD;
    font-family: inherit;
    font-size: 1rem;
    outline: none;
}

.limit-note {
    display: block;
    margin-top: 8px;
    color: #e67e22;
    font-weight: 600;
    font-size: 0.85rem;
}

.note-box {
    display: flex;
    gap: 12px;
    background: #FFF9E6;
    padding: 1rem;
    border-radius: 12px;
    margin: 2rem 0;
    border-left: 4px solid #FFC107;
}

.note-box i {
    color: #FFC107;
    margin-top: 3px;
}

.note-box p {
    font-size: 0.85rem;
    color: #856404;
    line-height: 1.5;
}

.btn-confirm-slip {
    width: 100%;
    padding: 18px;
    background: var(--primary);
    color: white;
    border: none;
    border-radius: 15px;
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    transition: 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
}

.btn-confirm-slip:hover {
    background: #144013;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(26, 83, 25, 0.2);
}
</style>

<%- include('../components/footer') %>
